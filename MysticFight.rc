#include "resource.h"
#include "winres.h"

/////////////////////////////////////////////////////////////////////////////
//
// Icon
//
IDI_ICON1               ICON                    "favicon.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Wave
//
IDR_WAV_LIGHTS_ON       WAVE                    "leds_on.wav"
IDR_WAV_LIGHTS_OFF      WAVE                    "leds_off.wav"

/////////////////////////////////////////////////////////////////////////////
//
// BINARY
//
IDR_MSI_DLL             BINARY                  "MysticLight_SDK.dll"

/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//
IDD_SETTINGS DIALOGEX 0, 0, 340, 360
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "MysticFight Settings - by tonikelope"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
CONTROL         "", IDC_TAB_PROFILES, "SysTabControl32", WS_TABSTOP, 7, 5, 326, 15

// --- PROFILE LAYER ---
LTEXT           "Profile Label:", IDC_LBL_PROFILE_NAME, 15, 27, 45, 8
EDITTEXT        IDC_EDIT_LABEL, 65, 25, 185, 12, ES_AUTOHSCROLL
CONTROL         "Set as Active Profile", IDC_CHK_ACTIVE_PROFILE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 255, 26, 80, 10

// 1. MSI HARDWARE CONTROL
GROUPBOX        "MSI Hardware Control", IDC_GRP_MSI, 7, 45, 326, 50
LTEXT           "Device:", IDC_LBL_DEVICE, 15, 58, 30, 8
COMBOBOX        IDC_COMBO_DEVICE, 50, 56, 275, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
LTEXT           "Area:", IDC_LBL_AREA, 15, 76, 30, 8
COMBOBOX        IDC_COMBO_AREA, 50, 74, 275, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

// 2. DATA SOURCE
GROUPBOX        "LibreHardwareMonitor (Data source: HTTP)", IDC_GRP_SOURCE, 7, 100, 326, 55
LTEXT           "Temperature Sensor:", IDC_LBL_TEMP_SENS, 15, 112, 200, 8
COMBOBOX        IDC_SENSOR_ID, 15, 122, 310, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
LTEXT           "Web Server:", IDC_LBL_WEB_SRV, 15, 139, 45, 8
EDITTEXT        IDC_EDIT_SERVER, 65, 137, 260, 12, ES_AUTOHSCROLL

// 3. THRESHOLDS 
GROUPBOX        "Temperature Thresholds and Colors", IDC_GRP_THRESHOLDS, 7, 160, 326, 95

LTEXT           "LOW:", IDC_LBL_LOW, 15, 177, 45, 8
EDITTEXT        IDC_TEMP_LOW, 65, 175, 22, 12, ES_CENTER | ES_NUMBER
LTEXT           "ºC", IDC_LBL_C1, 90, 177, 12, 8
LTEXT           "Color (hex):", IDC_LBL_HEX1, 120, 177, 42, 8
EDITTEXT        IDC_HEX_LOW, 165, 175, 55, 12, ES_CENTER | ES_AUTOHSCROLL | ES_UPPERCASE

LTEXT           "MEDIUM:", IDC_LBL_MED, 15, 197, 45, 8
EDITTEXT        IDC_TEMP_MED, 65, 195, 22, 12, ES_CENTER | ES_NUMBER
LTEXT           "ºC", IDC_LBL_C2, 90, 197, 12, 8
LTEXT           "Color (hex):", IDC_LBL_HEX2, 120, 197, 42, 8
EDITTEXT        IDC_HEX_MED, 165, 195, 55, 12, ES_CENTER | ES_AUTOHSCROLL | ES_UPPERCASE

LTEXT           "HIGH:", IDC_LBL_HIGH, 15, 217, 45, 8
EDITTEXT        IDC_TEMP_HIGH, 65, 215, 22, 12, ES_CENTER | ES_NUMBER
LTEXT           "ºC", IDC_LBL_C3, 90, 217, 12, 8
LTEXT           "Color (hex):", IDC_LBL_HEX3, 120, 217, 42, 8
EDITTEXT        IDC_HEX_HIGH, 165, 215, 55, 12, ES_CENTER | ES_AUTOHSCROLL | ES_UPPERCASE

PUSHBUTTON      "Reset Defaults", IDC_BTN_RESET, 255, 235, 70, 14

// 4. ADVANCED SETTINGS
GROUPBOX        "Performance & Advanced Settings", IDC_GRP_ADVANCED, 7, 260, 326, 75
LTEXT           "Sensor Update:", IDC_LBL_ADV_SENSOR, 15, 277, 60, 8
COMBOBOX        IDC_COMBO_SENSOR_UPDATE, 80, 275, 60, 60, CBS_DROPDOWNLIST | WS_TABSTOP
LTEXT           "LED Refresh:", IDC_LBL_ADV_LED, 15, 294, 60, 8
COMBOBOX        IDC_COMBO_LED_FPS, 80, 292, 60, 60, CBS_DROPDOWNLIST | WS_TABSTOP
LTEXT           "Smoothing:", IDC_LBL_ADV_SMOOTH, 15, 311, 60, 8
COMBOBOX        IDC_COMBO_SMOOTHING, 80, 309, 60, 60, CBS_DROPDOWNLIST | WS_TABSTOP
PUSHBUTTON      "Reset Defaults", IDC_BTN_RESET_ADVANCED, 255, 309, 70, 14

// --- SHORTCUTS LAYER ---
GROUPBOX        "Global Hotkeys Configuration", IDC_GRP_SHORTCUTS, 7, 30, 326, 305, NOT WS_VISIBLE

LTEXT           "Toggle ON/OFF:", IDC_LBL_TOGGLE, 20, 50, 80, 8, NOT WS_VISIBLE
CONTROL         "", IDC_HK_TOGGLE, "msctls_hotkey32", WS_BORDER | WS_TABSTOP | NOT WS_VISIBLE, 120, 48, 180, 14

LTEXT           "Activate Profile 1:", IDC_LBL_P1, 20, 75, 80, 8, NOT WS_VISIBLE
CONTROL         "", IDC_HK_P1, "msctls_hotkey32", WS_BORDER | WS_TABSTOP | NOT WS_VISIBLE, 120, 73, 180, 14

LTEXT           "Activate Profile 2:", IDC_LBL_P2, 20, 100, 80, 8, NOT WS_VISIBLE
CONTROL         "", IDC_HK_P2, "msctls_hotkey32", WS_BORDER | WS_TABSTOP | NOT WS_VISIBLE, 120, 98, 180, 14

LTEXT           "Activate Profile 3:", IDC_LBL_P3, 20, 125, 80, 8, NOT WS_VISIBLE
CONTROL         "", IDC_HK_P3, "msctls_hotkey32", WS_BORDER | WS_TABSTOP | NOT WS_VISIBLE, 120, 123, 180, 14

LTEXT           "Activate Profile 4:", IDC_LBL_P4, 20, 150, 80, 8, NOT WS_VISIBLE
CONTROL         "", IDC_HK_P4, "msctls_hotkey32", WS_BORDER | WS_TABSTOP | NOT WS_VISIBLE, 120, 148, 180, 14

LTEXT           "Activate Profile 5:", IDC_LBL_P5, 20, 175, 80, 8, NOT WS_VISIBLE
CONTROL         "", IDC_HK_P5, "msctls_hotkey32", WS_BORDER | WS_TABSTOP | NOT WS_VISIBLE, 120, 173, 180, 14

PUSHBUTTON      "Reset Hotkeys", IDC_BTN_RESET_SHORTCUTS, 230, 195, 70, 14, NOT WS_VISIBLE

// Buttons
CONTROL         "Run on Windows startup", IDC_CHK_STARTUP, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 10, 343, 95, 10
DEFPUSHBUTTON   "Save", IDOK, 225, 340, 50, 14
PUSHBUTTON      "Cancel", IDCANCEL, 280, 340, 50, 14
END


IDD_ABOUT DIALOGEX 0, 0, 190, 110
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About MysticFight"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    CONTROL         "", IDC_ABOUT_ICON, "Static", SS_ICON | SS_REALSIZEIMAGE, 15, 15, 32, 32
    LTEXT           "", IDC_ABOUT_VERSION, 55, 15, 120, 8, SS_NOPREFIX
    LTEXT           "By tonikelope", IDC_STATIC, 55, 26, 120, 8
    LTEXT           "MSI Mystic Light CPU Temperature Profile Replacement", IDC_STATIC, 55, 40, 120, 20
    LTEXT           "Visit GitHub Project", IDC_GITHUB_LINK, 55, 65, 120, 8, SS_NOTIFY
    DEFPUSHBUTTON   "Close", IDOK, 133, 89, 50, 14
END
